// Software Library Directory — Prisma Schema
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Core: Library
// ---------------------------------------------------------------------------

model Library {
  id             String   @id @default(cuid())
  name           String   @unique
  slug           String   @unique
  shortSummary   String?  // one-liner shown on search cards
  description    String?  // full description
  functionDesc   String?  // what problem it solves / use-case summary
  socialImpact   String?  // community impact, adoption notes
  exampleCode    String?  @db.Text // code snippet showing usage
  officialUrl    String?  // docs / homepage URL
  repositoryUrl  String?  // GitHub / GitLab URL
  costMinUSD     Int?     // 0 = free; stored in cents for precision
  costMaxUSD     Int?
  developerId    String?
  organizationId String?
  scrapedAt      DateTime? // when data was last fetched from an external source
  dataSource     String?   // 'manual', 'curated', 'scraped'
  tags           String[]  @default([]) // searchable keywords: npm keywords, pypi classifiers, extracted terms
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  developer    Developer?    @relation(fields: [developerId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])

  versions     Version[]
  features     Feature[]        // notable capabilities / integrations

  // Self-referential dependencies (libraries this one depends on)
  dependsOn    LibraryDep[]  @relation("LibraryDependencies")
  dependents   LibraryDep[]  @relation("LibraryDependents")

  categories Library_Category[]
  platforms  Library_Platform[]  // OS / runtime compatibility
  languages  Library_Language[]  // programming language(s)

  @@index([slug])
  @@index([developerId])
  @@index([organizationId])
}

// ---------------------------------------------------------------------------
// Developer & Organization
// ---------------------------------------------------------------------------

model Developer {
  id        String    @id @default(cuid())
  name      String    @unique
  url       String?
  libraries Library[]
}

model Organization {
  id        String    @id @default(cuid())
  name      String    @unique
  url       String?
  libraries Library[]
}

// ---------------------------------------------------------------------------
// Category  (Web, Data Science, Security, DevOps, etc.)
// ---------------------------------------------------------------------------

model Category {
  id        String             @id @default(cuid())
  name      String             @unique
  libraries Library_Category[]
}

model Library_Category {
  libraryId  String
  categoryId String
  assignedAt DateTime @default(now())

  library  Library  @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([libraryId, categoryId])
  @@index([categoryId])
}

// ---------------------------------------------------------------------------
// Platform  (macOS, Windows, Linux, Web, Android, iOS, Cross-platform)
// ---------------------------------------------------------------------------

model Platform {
  id        String             @id @default(cuid())
  name      String             @unique
  libraries Library_Platform[]
}

model Library_Platform {
  libraryId  String
  platformId String

  library  Library  @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  platform Platform @relation(fields: [platformId], references: [id], onDelete: Cascade)

  @@id([libraryId, platformId])
  @@index([platformId])
}

// ---------------------------------------------------------------------------
// Language  (Python, JavaScript, TypeScript, Java, Rust, Go, etc.)
// ---------------------------------------------------------------------------

model Language {
  id        String             @id @default(cuid())
  name      String             @unique
  libraries Library_Language[]
}

model Library_Language {
  libraryId  String
  languageId String

  library  Library  @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  language Language @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@id([libraryId, languageId])
  @@index([languageId])
}

// ---------------------------------------------------------------------------
// Version history
// ---------------------------------------------------------------------------

model Version {
  id         String    @id @default(cuid())
  libraryId  String
  name       String    // e.g. "4.2.1"
  releasedAt DateTime?
  notes      String?

  library Library @relation(fields: [libraryId], references: [id], onDelete: Cascade)

  @@index([libraryId])
}

// ---------------------------------------------------------------------------
// Feature  (notable capabilities / integrations of a library)
// ---------------------------------------------------------------------------

model Feature {
  id        String  @id @default(cuid())
  libraryId String
  name      String  // e.g. "Async support", "OAuth2 integration"
  spec      String? // additional detail
  required  Boolean @default(true)

  library Library @relation(fields: [libraryId], references: [id], onDelete: Cascade)

  @@index([libraryId])
}

// ---------------------------------------------------------------------------
// Library → Library dependency (self-referential)
// ---------------------------------------------------------------------------

model LibraryDep {
  id          String @id @default(cuid())
  libraryId   String
  dependsOnId String

  library   Library @relation("LibraryDependencies", fields: [libraryId], references: [id], onDelete: Cascade)
  dependsOn Library @relation("LibraryDependents", fields: [dependsOnId], references: [id], onDelete: Cascade)

  @@unique([libraryId, dependsOnId])
  @@index([dependsOnId])
}

// ---------------------------------------------------------------------------
// NextAuth.js models (unchanged)
// ---------------------------------------------------------------------------

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("user")
  accounts      Account[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
